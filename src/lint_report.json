   const custos = await executeQuery(`SELECT SUM(valor) as soma FROM compras WHERE is_deleted = 0`); // V1 compat\n            \n            const receita = vendas.rows.item(0).soma || 0;\n            const despesa = custos.rows.item(0).soma || 0;\n\n            return {\n                receita,\n                despesa,\n                lucro: receita - despesa,\n                margem: receita > 0 ? ((receita - despesa) / receita) * 100 : 0\n            };\n        } catch (error) {\n            return { receita: 0, despesa: 0, lucro: 0, margem: 0 };\n        }\n    }\n};\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\AutoSyncService.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\BackupService.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\ColheitaService.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\EstoqueService.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\FertilizationService.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\services\\MenuConfigServi