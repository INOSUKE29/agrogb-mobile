sedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AgroButton.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AgroFAB.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AgroInput.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AnalyticsDashboard.js","messages":[{"ruleId":"no-unused-vars","severity":1,"message":"'PieChart' is defined but never used.","line":4,"column":31,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":39,"suggestions":[{"messageId":"removeVar","data":{"varName":"PieChart"},"fix":{"range":[123,133],"text":""},"desc":"Remove unused variable 'PieChart'."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\nimport React from 'react';\nimport { View, Text, StyleSheet, Dimensions } from 'react-native';\nimport { BarChart, LineChart, PieChart } from 'react-native-chart-kit';\n\nconst screenWidth = Dimensions.get('window').width;\n\nexport default function AnalyticsDashboard({ productivityData, financialData }) {\n    \n    const chartConfig = {\n        backgroundGradientFrom: \"#FFF\",\n        backgroundGradientTo: \"#FFF\",\n        color: (opacity = 1) => `rgba(21, 128, 61, ${opacity})`,\n        labelColor: (opacity = 1) => `rgba(107, 114, 128, ${opacity})`,\n        strokeWidth: 2,\n        barPercentage: 0.5,\n        useShadowColorFromDataset: false\n    };\n\n    const hasProductivity = productivityData && productivityData.length > 0;\n\n    return (\n        <View style={styles.container}>\n            <Text style={styles.mainTitle}>Dashboard Anal├¡tico ­ƒôè</Text>\n\n            {/* Resumo Financeiro */}\n            <View style={styles.statsRow}>\n                <View style={[styles.statCard, { borderLeftColor: '#10B981' }]}>\n                    <Text style={styles.statLabel}>Receita</Text>\n                    <Text style={[styles.statValue, { color: '#10B981' }]}>R$ {financialData.receita.toLocaleString()}</Text>\n                </View>\n                <View style={[styles.statCard, { borderLeftColor: '#EF4444' }]}>\n                    <Text style={styles.statLabel}>Despesa</Text>\n                    <Text style={[styles.statValue, { color: '#EF4444' }]}>R$ {financialData.despesa.toLocaleString()}</Text>\n                </View>\n            </View>\n\n            {/* Gr├ífico de Produtividade por Talh├úo */}\n            <Text style={styles.chartTitle}>Produtividade por Talh├úo (Kg/Ha)</Text>\n            {hasProductivity ? (\n                <BarChart\n                    data={{\n                        labels: productivityData.map(d => d.talhao),\n                        datasets: [{ data: productivityData.map(d => d.produtividade || 0) }]\n                    }}\n                    width={screenWidth - 48}\n                    height={220}\n                    yAxisLabel=\"\"\n                    yAxisSuffix=\"\"\n                    chartConfig={chartConfig}\n                    verticalLabelRotation={30}\n                    style={styles.chart}\n                />\n            ) : (\n                <View style={styles.emptyChart}>\n                    <Text style={styles.emptyText}>Sem dados de colheita/├írea suficientes.</Text>\n                </View>\n            )}\n\n            {/* Gr├ífico de Evolu├º├úo (Mockup p/ V3) */}\n            <Text style={styles.chartTitle}>Evolu├º├úo da Produ├º├úo</Text>\n            <LineChart\n                data={{\n                    labels: [\"Jan\", \"Fev\", \"Mar\", \"Abr\"],\n                    datasets: [{ data: [20, 45, 28, 80] }]\n                }}\n                width={screenWidth - 48}\n                height={180}\n                chartConfig={chartConfig}\n                bezier\n                style={styles.chart}\n            />\n        </View>\n    );\n}\n\nconst styles = StyleSheet.create({\n    container: { padding: 16 },\n    mainTitle: { fontSize: 22, fontWeight: 'bold', color: '#111827', marginBottom: 20 },\n    statsRow: { flexDirection: 'row', justifyContent: 'space-between', marginBottom: 24 },\n    statCard: { flex: 1, backgroundColor: '#FFF', padding: 16, borderRadius: 12, marginHorizontal: 4, elevation: 4, borderLeftWidth: 4 },\n    statLabel: { fontSize: 12, color: '#6B7280', textTransform: 'uppercase' },\n    statValue: { fontSize: 16, fontWeight: 'bold', marginTop: 4 },\n    chartTitle: { fontSize: 16, fontWeight: '600', color: '#374151', marginTop: 16, marginBottom: 8 },\n    chart: { marginVertical: 8, borderRadius: 16, paddingRight: 40 },\n    emptyChart: { height: 100, justifyContent: 'center', alignItems: 'center', backgroundColor: '#F3F4F6', borderRadius: 12 },\n    emptyText: { color: '#9CA3AF', fontSize: 12 }\n});\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AppButton.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Bruno\\Documents\\AgroGB\\mobile_app\\src\\ui\\components\\AppCard.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixa