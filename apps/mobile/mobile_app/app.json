{
  "expo": {
    "name": "AgroGB Mobile",
    "slug": "agrogb-mobile",
    "scheme": "agrogb",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrogb.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Permitir salvar relatórios e fotos.",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos",
        "NSFaceIDUsageDescription": "Allow $(PRODUCT_NAME) to use Face ID"
      }
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10B981"
      },
      "allowBackup": false,
      "package": "com.agrogb.mobile",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.DETECT_SCREEN_CAPTURE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/dd5b4ea9-8594-4f37-86a3-b5ef94900b23"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para fotos do plano de adubação.",
          "microphonePermission": "Permitir acesso ao microfone para vídeos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir salvar relatórios e fotos.",
          "saveToPhotosPermission": "Permitir salvar arquivos no dispositivo.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.22",
            "extraGradleProps": {
              "org.gradle.jvmargs": "-Xmx4g -XX:MaxMetaspaceSize=1g",
              "org.gradle.daemon": "false"
            }
          }
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      "expo-localization",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que o AgroGB acesse sua localização para previsão do clima nas fazendas."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "dd5b4ea9-8594-4f37-86a3-b5ef94900b23"
      }
    },
    "owner": "inosuke29"
  }
}
